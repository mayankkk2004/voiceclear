{
  "version": "0.2.0",
  "configurations": [
    {
      "name": "Flask Backend",
      "type": "debugpy",
      "request": "launch",
      "module": "flask",
      "args": ["--app", "run.py", "--debug", "run", "--port", "5000"],
      "cwd": "${workspaceFolder}/backend",
      "env": {
        "FLASK_ENV": "development",
        "FLASK_DEBUG": "1"
      },
      "envFile": "${workspaceFolder}/backend/.env",
      "jinja": true,
      "justMyCode": false
    },
    {
      "name": "Next.js Frontend",
      "type": "node",
      "request": "launch",
      "runtimeExecutable": "npm",
      "runtimeArgs": ["run", "dev"],
      "cwd": "${workspaceFolder}/frontend",
      "serverReadyAction": {
        "pattern": "Local:\\s+http://localhost:([0-9]+)",
        "uriFormat": "http://localhost:%s",
        "action": "openExternally"
      }
    }
  ],
  "compounds": [
    {
      "name": "Full Stack (Backend + Frontend)",
      "configurations": ["Flask Backend", "Next.js Frontend"],
      "stopAll": true
    }
  ]
}
