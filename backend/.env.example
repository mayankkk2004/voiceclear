FLASK_ENV=development
SECRET_KEY=change-this-secret
JWT_SECRET_KEY=change-this-jwt-secret
JWT_ACCESS_TOKEN_EXPIRES_DAYS=7
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/speechtotext
DEEPINFRA_API_KEY=
DEEPINFRA_MODEL=openai/whisper-large-v3
DEEPINFRA_FAST_MODEL=openai/whisper-large-v3
DEEPINFRA_CONNECT_TIMEOUT_SECONDS=8
DEEPINFRA_TIMEOUT_SECONDS=45
DEEPINFRA_MAX_RETRIES=2
FRONTEND_ORIGIN=http://localhost:3000
FRONTEND_ORIGINS=http://localhost:3000
MAX_AUDIO_MB=15
